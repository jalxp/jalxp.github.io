---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import { readingTime } from '../../utils/readingTime';
import { site } from '../../config/site';

export async function getStaticPaths() {
  const posts = await getCollection('writing', ({ data }) => !data.draft);
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const { minutes } = readingTime(post.body ?? '');
const sourceUrl = site.repo ? `${site.repo}/blob/main/${site.postsPath}/${post.id}.md` : null;

const fmtDate = (d: Date) => {
  const y = d.getUTCFullYear();
  const m = String(d.getUTCMonth() + 1).padStart(2, '0');
  const day = String(d.getUTCDate()).padStart(2, '0');
  return `${y}.${m}.${day}`;
};
---
<BaseLayout title={post.data.title} description={post.data.description} ogType="article">
  <article class="page-enter post">
    <header class="post-head">
      <div class="post-meta">
        <span class="post-date tabnum">{fmtDate(post.data.pubDate)}</span>
        <span class="post-read tabnum">{minutes} min read</span>
        {post.data.tags.map((t) => <span class="post-tag">#{t}</span>)}
      </div>
      <h1 class="post-title">{post.data.title}</h1>
      <p class="post-desc">{post.data.description}</p>
    </header>

    <div class="prose">
      <Content />
    </div>

    <footer class="post-foot">
      <a href="/writing/">← back to writing</a>
      {sourceUrl && (
        <a class="post-src" href={sourceUrl} target="_blank" rel="noopener noreferrer">view source ↗</a>
      )}
    </footer>
  </article>
</BaseLayout>

<style>
  .post { display: flex; flex-direction: column; gap: 28px; }

  .post-head {
    padding: 28px 0 22px;
    border-bottom: 1px dashed var(--line);
  }
  .post-meta {
    display: flex; gap: 12px; align-items: center; flex-wrap: wrap;
    font-family: var(--mono-ui);
    font-size: 11px;
    color: var(--ink-muted);
    margin-bottom: 12px;
    letter-spacing: .06em;
  }
  .post-date { color: var(--accent); }
  .post-read { color: var(--ink-muted); }
  .post-read::before { content: '· '; opacity: .6; margin-right: 2px; }
  .post-tag {
    color: var(--ink-dim);
    border: 1px solid var(--line-soft);
    padding: 1px 6px;
    border-radius: 2px;
  }
  .post-title {
    margin: 0;
    font-family: var(--mono-display);
    font-size: 28px;
    line-height: 1.2;
    color: var(--ink);
    letter-spacing: .01em;
  }
  .post-desc {
    margin: 10px 0 0;
    font-family: var(--mono-body);
    font-size: 14px;
    color: var(--ink-dim);
    max-width: 64ch;
  }

  .prose { font-family: var(--mono-body); font-size: 15px; line-height: 1.8; color: var(--ink-dim); max-width: 72ch; }
  .prose :global(h2) {
    margin: 40px 0 14px;
    font-family: var(--mono-display);
    font-size: 20px;
    color: var(--ink);
    letter-spacing: .02em;
    border-bottom: 1px dashed var(--line);
    padding-bottom: 8px;
  }
  .prose :global(h2::before) { content: '// '; color: var(--accent); opacity: .7; }
  .prose :global(h3) {
    margin: 26px 0 10px;
    font-family: var(--mono-ui);
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: .15em;
    color: var(--accent);
  }
  .prose :global(p) { margin: 0 0 16px; color: var(--ink-dim); }
  .prose :global(a) { color: var(--accent); text-decoration: underline; text-underline-offset: 3px; }
  .prose :global(code) {
    font-family: var(--mono-ui);
    font-size: 12.5px;
    background: var(--panel-2);
    color: var(--accent);
    padding: 1px 5px;
    border-radius: 2px;
    border: 1px solid var(--line-soft);
  }
  .prose :global(pre) {
    font-family: var(--mono-ui);
    font-size: 12.5px;
    background: var(--panel-2);
    padding: 14px 16px;
    border: 1px solid var(--line);
    border-radius: var(--radius-sm);
    overflow-x: auto;
    line-height: 1.6;
    margin: 0 0 18px;
  }
  .prose :global(pre code) {
    background: transparent;
    padding: 0;
    border: 0;
    color: var(--ink);
  }
  .prose :global(ul), .prose :global(ol) { padding-left: 22px; margin: 0 0 16px; }
  .prose :global(li) { padding: 3px 0; }
  .prose :global(li::marker) { color: var(--accent); }
  .prose :global(blockquote) {
    border-left: 3px solid var(--accent);
    background: var(--panel);
    padding: 10px 16px;
    margin: 0 0 18px;
    color: var(--ink);
    font-style: italic;
  }
  .prose :global(hr) {
    border: 0;
    border-top: 1px dashed var(--line);
    margin: 26px 0;
  }
  .prose :global(strong) { color: var(--ink); font-weight: 600; }

  .post-foot {
    padding-top: 22px;
    border-top: 1px dashed var(--line);
    font-family: var(--mono-ui);
    font-size: 12px;
    display: flex;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
  }
  .post-foot a { color: var(--ink-muted); text-decoration: none; }
  .post-foot a:hover { color: var(--accent); }
  .post-src { border-bottom: 1px dashed var(--line); }
</style>
