---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/primitives/SectionHeader.astro';
import Win from '../components/primitives/Win.astro';
import { uses } from '../config/uses';
---
<BaseLayout title="uses" description="The hardware, editors, and services João Aleixo actually uses.">
  <div class="page-enter uses">
    <SectionHeader
      kicker="// cat ./uses.md"
      num="08"
      title="uses"
      subtitle="the boring list of what I actually use"
    />

    <Win title="uses.md" hasFooter>
      <div slot="footer">
        <span>inspired by /uses pages everywhere</span>
        <span>last reviewed · {new Date().toISOString().slice(0, 10)}</span>
      </div>

      <div class="intro">
        <p>
          No affiliate links. No sponsorships. Just the stuff I reach for. If
          something here goes stale, it'll be because I moved on, not because
          someone paid me to.
        </p>
      </div>

      {uses.map((g) => (
        <section class="u-grp">
          <header class="u-head">
            <h2>// {g.title}</h2>
            {g.subtitle && <p class="u-sub">{g.subtitle}</p>}
          </header>
          <ul class="u-list">
            {g.items.map((it) => (
              <li>
                <span class="u-name">{it.name}</span>
                {it.note && <span class="u-note">{it.note}</span>}
              </li>
            ))}
          </ul>
        </section>
      ))}
    </Win>
  </div>
</BaseLayout>

<style>
  .uses { display: flex; flex-direction: column; gap: 20px; }
  .intro {
    font-family: var(--mono-body);
    font-size: 13.5px;
    line-height: 1.8;
    color: var(--ink-dim);
    max-width: 72ch;
    margin-bottom: 22px;
  }
  .intro p { margin: 0; }

  .u-grp + .u-grp { margin-top: 26px; }
  .u-head { margin-bottom: 10px; }
  .u-head h2 {
    margin: 0;
    font-family: var(--mono-display);
    font-size: 18px;
    color: var(--accent);
    letter-spacing: .02em;
  }
  .u-sub {
    margin: 4px 0 0;
    font-family: var(--mono-ui);
    font-size: 11px;
    color: var(--ink-muted);
    letter-spacing: .06em;
  }

  .u-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .u-list li {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 14px;
    align-items: baseline;
    padding: 8px 2px;
    font-family: var(--mono-ui);
    font-size: 13px;
  }
  .u-list li + li { border-top: 1px dashed var(--line-soft); }
  .u-name { color: var(--ink); }
  .u-name::before { content: '› '; color: var(--accent); opacity: .5; }
  .u-note {
    color: var(--ink-muted);
    font-size: 11px;
    letter-spacing: .04em;
  }

  @media (max-width: 500px) {
    .u-list li { grid-template-columns: 1fr; gap: 2px; }
  }
</style>
