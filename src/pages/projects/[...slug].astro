---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Win from '../../components/primitives/Win.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects', ({ data }) => !data.draft);
  return projects.map((p) => ({ params: { slug: p.id }, props: { project: p } }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const d = project.data;
---
<BaseLayout title={d.name} description={d.description} ogType="article">
  <article class="page-enter project">
    <header class="proj-head">
      <nav class="proj-kicker" aria-label="breadcrumb">
        <span class="sep">//</span>
        <a href="/projects/">projects</a>
        <span class="sep">/</span>
        <span class="crumb-current">{project.id}</span>
      </nav>
      <h1 class="proj-title">{d.name}</h1>
      <div class="proj-tag">— {d.tagline}</div>

      <div class="proj-meta">
        <span class="proj-year tabnum">{d.year}</span>
        <span class:list={['proj-status', `s-${d.status}`]}>
          <span class="dot" />{d.status}
        </span>
      </div>

      <div class="proj-tech">
        {d.tech.map((t) => <span class="chip">{t}</span>)}
      </div>

      {(d.link || d.repo) && (
        <div class="proj-links">
          {d.link && <a href={d.link} target="_blank" rel="noopener noreferrer">visit →</a>}
          {d.repo && <a href={d.repo} target="_blank" rel="noopener noreferrer">repo →</a>}
        </div>
      )}
    </header>

    <Win title={`${project.id}.md`}>
      <div class="prose">
        <Content />
      </div>
    </Win>

    <footer class="proj-foot">
      <a href="/projects/">← all projects</a>
    </footer>
  </article>
</BaseLayout>

<style>
  .project { display: flex; flex-direction: column; gap: 24px; }
  .proj-head { padding: 28px 0 8px; display: flex; flex-direction: column; gap: 10px; }
  .proj-kicker {
    font-family: var(--mono-ui);
    font-size: 10px;
    letter-spacing: .2em;
    text-transform: uppercase;
    color: var(--ink-muted);
    display: inline-flex;
    gap: 6px;
    align-items: center;
  }
  .proj-kicker .sep { opacity: .6; }
  .proj-kicker a {
    color: var(--ink-muted);
    text-decoration: none;
    border-bottom: 1px dashed transparent;
    transition: color .15s ease, border-color .15s ease;
  }
  .proj-kicker a:hover {
    color: var(--accent);
    border-bottom-color: color-mix(in oklab, var(--accent) 40%, var(--line));
  }
  .proj-kicker .crumb-current { color: var(--ink); }
  .proj-title {
    margin: 0;
    font-family: var(--mono-display);
    font-size: 34px;
    color: var(--ink);
    line-height: 1.1;
  }
  .proj-tag { font-family: var(--mono-ui); font-size: 14px; color: var(--ink-dim); }

  .proj-meta { display: flex; gap: 12px; align-items: center; margin-top: 6px; }
  .proj-year { font-family: var(--mono-ui); font-size: 12px; color: var(--ink-muted); }
  .proj-status {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 3px 8px;
    border: 1px solid var(--line);
    border-radius: 2px;
    font-family: var(--mono-ui);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: .12em;
  }
  .proj-status .dot { width: 6px; height: 6px; border-radius: 50%; background: var(--ink-muted); }
  .s-shipping, .s-live {
    color: var(--accent);
    border-color: color-mix(in oklab, var(--accent) 40%, var(--line));
  }
  .s-shipping .dot, .s-live .dot {
    background: var(--accent);
    box-shadow: 0 0 6px var(--accent);
  }
  .s-beta, .s-wip, .s-in-progress {
    color: var(--amber);
    border-color: color-mix(in oklab, var(--amber) 40%, var(--line));
  }
  .s-beta .dot, .s-wip .dot, .s-in-progress .dot { background: var(--amber); }

  .proj-tech { display: flex; gap: 6px; flex-wrap: wrap; margin-top: 4px; }
  .proj-links { display: flex; gap: 16px; margin-top: 6px; font-family: var(--mono-ui); font-size: 12px; }
  .proj-links a {
    color: var(--ink-dim);
    text-decoration: none;
    border-bottom: 1px dashed var(--line);
  }
  .proj-links a:hover {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }

  .prose { font-family: var(--mono-body); font-size: 14px; line-height: 1.8; color: var(--ink-dim); max-width: 72ch; }
  .prose :global(h2) {
    margin: 28px 0 12px;
    font-family: var(--mono-display);
    font-size: 18px;
    color: var(--ink);
  }
  .prose :global(h2::before) { content: '// '; color: var(--accent); opacity: .7; }
  .prose :global(p) { margin: 0 0 14px; }
  .prose :global(ul) { padding-left: 22px; margin: 0 0 16px; }
  .prose :global(li) { padding: 3px 0; }
  .prose :global(li::marker) { color: var(--accent); }
  .prose :global(strong) { color: var(--ink); }
  .prose :global(code) {
    font-family: var(--mono-ui);
    font-size: 12.5px;
    background: var(--panel-2);
    color: var(--accent);
    padding: 1px 5px;
    border-radius: 2px;
    border: 1px solid var(--line-soft);
  }

  .proj-foot {
    padding-top: 22px;
    border-top: 1px dashed var(--line);
    font-family: var(--mono-ui);
    font-size: 12px;
  }
  .proj-foot a { color: var(--ink-muted); }
  .proj-foot a:hover { color: var(--accent); }
</style>
