---
import '../styles/global.css';
import Sidebar from '../components/Sidebar.astro';
import BootSequence from '../components/islands/BootSequence.tsx';
import HelpOverlay from '../components/islands/HelpOverlay.tsx';
import { site } from '../config/site';
import { author } from '../config/author';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
}
const { title, description, ogImage, ogType = 'website' } = Astro.props;

const pageTitle = title ? `${title} — ${site.title}` : site.title;
const pageDesc = description ?? site.description;
const canonical = new URL(Astro.url.pathname, site.url).toString();
// OG image: explicit prop > generated /og/<slug>.png > /og-default.svg
const ogSlug = (() => {
  const p = Astro.url.pathname.replace(/\/+$/, '').replace(/^\/+/, '');
  if (!p) return 'default';
  if (p.startsWith('writing/') && p !== 'writing') return p.slice('writing/'.length);
  return p;
})();
const ogSlugWhitelist = new Set(['default', 'about', 'projects', 'writing', 'contact', 'uses', 'links']);
const hasGeneratedOg = ogSlugWhitelist.has(ogSlug) || Astro.url.pathname.startsWith('/writing/');
const ogImageUrl = ogImage
  ? new URL(ogImage, site.url).toString()
  : hasGeneratedOg
    ? new URL(`/og/${ogSlug}.png`, site.url).toString()
    : new URL('/og-default.svg', site.url).toString();

const accent = site.defaults.accent;
const theme = site.defaults.theme;
const fontpair = site.defaults.fontpair;
const scanlines = site.defaults.scanlines;

const navRoutes = site.menu.map((m) => m.href);

// CSP applied only in prod builds — dev needs looser rules for Vite HMR
const csp = [
  "default-src 'self'",
  "script-src 'self' 'unsafe-inline'",
  "style-src 'self' 'unsafe-inline' https://fonts.googleapis.com",
  "font-src 'self' https://fonts.gstatic.com",
  "img-src 'self' data:",
  "connect-src 'self'",
  "object-src 'none'",
  "base-uri 'self'",
  "form-action 'self'",
].join('; ');

const pathname = Astro.url.pathname.replace(/\/+$/, '') || '/';
const matched = site.menu.find((m) => {
  const n = m.href.replace(/\/+$/, '') || '/';
  return n === '/' ? pathname === '/' : pathname === n || pathname.startsWith(n + '/');
});
const crumbSeg = matched?.label ?? pathname.split('/').filter(Boolean).pop() ?? 'home';
---
<!DOCTYPE html>
<html lang={site.lang} data-theme={theme} data-accent={accent} data-fontpair={fontpair}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    {import.meta.env.PROD && <meta http-equiv="Content-Security-Policy" content={csp} />}
    <meta name="description" content={pageDesc} />
    <meta name="author" content={author.name} />
    <title>{pageTitle}</title>
    <link rel="canonical" href={canonical} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="alternate" type="application/rss+xml" title={`${site.title} — writing`} href="/rss.xml" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />

    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={site.title} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDesc} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:locale" content={site.locale} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDesc} />
    <meta name="twitter:image" content={ogImageUrl} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=DotGothic16&family=IBM+Plex+Mono:wght@400;600&family=JetBrains+Mono:wght@400;600&family=Major+Mono+Display&family=VT323&display=optional"
    />

    <script is:inline define:vars={{ defaultScanlines: scanlines }}>
      (() => {
        try {
          const html = document.documentElement;
          const raw = localStorage.getItem('jaPortfolio:prefs');
          const p = raw ? JSON.parse(raw) : {};
          if (p.accent)   html.dataset.accent = p.accent;
          if (p.theme) {
            html.dataset.theme = p.theme;
          } else if (window.matchMedia && window.matchMedia('(prefers-color-scheme: light)').matches) {
            html.dataset.theme = 'light';
          }
          if (p.fontpair) html.dataset.fontpair = p.fontpair;
          const scanFinal = (typeof p.scanlines === 'boolean') ? p.scanlines : defaultScanlines;
          document.addEventListener('DOMContentLoaded', () => {
            document.body.classList.toggle('scanlines', scanFinal);
          });
        } catch {}
      })();
    </script>
  </head>
  <body class={scanlines ? 'scanlines' : undefined}>
    <Sidebar />
    <main class="main">
      <header class="top">
        <div class="top-path">
          <span class="p-seg">~</span>
          <span class="p-sep">/</span>
          <span class="p-seg active">{crumbSeg}</span>
          <span class="p-caret" />
        </div>
      </header>

      <div class="col">
        <slot />
      </div>

      <footer class="foot">
        <div>
          <span>© {new Date().getFullYear()} {author.name.toLowerCase()}</span>
          <span class="sep">·</span>
          <a href="/uses/">uses</a>
          <span class="sep">·</span>
          <a href="/links/">links</a>
          <span class="sep">·</span>
          <a href="/privacy/">privacy</a>
        </div>
        <div>
          <span class="kbd-hint">1–{site.menu.length}</span>
          <span>navigate</span>
          <span class="sep">·</span>
          <span class="kbd-hint">?</span>
          <span>help</span>
        </div>
      </footer>
    </main>

    <BootSequence client:only="react" />
    <HelpOverlay client:only="react" menu={site.menu} />

    <script is:inline>
      /* stagger .win/.term grow-down reveal in document order */
      (() => {
        const run = () => {
          const nodes = document.querySelectorAll('.win, .term');
          nodes.forEach((n, i) => {
            n.style.animationDelay = `${Math.min(i, 6) * 70}ms`;
          });
        };
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', run);
        } else {
          run();
        }
      })();
    </script>

    <script is:inline define:vars={{ navRoutes }}>
      (() => {
        document.addEventListener('keydown', (e) => {
          if (e.metaKey || e.ctrlKey || e.altKey) return;
          const t = e.target;
          if (t instanceof HTMLElement &&
              (t.tagName === 'INPUT' || t.tagName === 'TEXTAREA' || t.isContentEditable)) return;
          const idx = parseInt(e.key, 10);
          if (!Number.isFinite(idx) || idx < 1 || idx > navRoutes.length) return;
          const href = navRoutes[idx - 1];
          if (href && window.location.pathname !== href) {
            window.location.href = href;
          }
        });
      })();
    </script>

    <style>
      .main {
        margin-left: 280px;
        min-height: 100vh;
        display: flex; flex-direction: column;
      }
      .top {
        position: sticky; top: 0; z-index: 9;
        display: flex; justify-content: space-between; align-items: center;
        padding: 12px 28px;
        background: color-mix(in oklab, var(--bg) 88%, transparent);
        backdrop-filter: blur(8px);
        border-bottom: 1px solid var(--line);
      }
      .top-path {
        font-family: var(--mono-ui); font-size: 12px;
        display: flex; align-items: center; gap: 4px;
      }
      .p-seg { color: var(--ink-dim); }
      .p-sep { color: var(--ink-muted); padding: 0 2px; }
      .p-seg.active { color: var(--accent); }
      .p-caret {
        display: inline-block;
        width: 7px; height: 12px;
        background: var(--accent);
        margin-left: 4px;
        animation: caret-blink 1.1s steps(2) infinite;
      }
      @keyframes caret-blink { 50% { opacity: 0; } }

      .col {
        flex: 1;
        max-width: 900px;
        width: 100%;
        padding: 28px 32px 60px;
        margin: 0 auto;
        box-sizing: border-box;
      }

      .foot {
        display: flex; justify-content: space-between; align-items: center;
        padding: 14px 28px;
        border-top: 1px solid var(--line);
        font-family: var(--mono-ui); font-size: 10px;
        color: var(--ink-muted);
        letter-spacing: .06em;
        text-transform: uppercase;
      }
      .foot .sep { margin: 0 8px; color: var(--line); }
      .foot a { color: var(--ink-muted); text-decoration: none; }
      .foot a:hover { color: var(--accent); }
      .foot .kbd-hint {
        display: inline-block;
        padding: 1px 5px;
        margin-right: 6px;
        border: 1px solid var(--line);
        border-bottom-width: 2px;
        border-radius: 2px;
        background: var(--panel-2);
        color: var(--ink-dim);
        font-size: 9px;
      }

      @media (max-width: 900px) {
        .main { margin-left: 0; }
        .col  { padding: 20px 16px 60px; }
        .top  { padding: 10px 16px; }
        .foot { padding: 12px 16px; flex-direction: column; gap: 6px; align-items: flex-start; }
      }
    </style>
  </body>
</html>
