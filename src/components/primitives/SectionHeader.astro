---
interface Props {
  kicker: string;
  num: string;
  title: string;
  subtitle?: string;
}
const { kicker, num, title, subtitle } = Astro.props;
---
<header class="sh">
  <div class="sh-text">
    <div class="sh-kicker">{kicker}</div>
    <h1 class="sh-title">{title}</h1>
    {subtitle && <div class="sh-sub">{subtitle}</div>}
  </div>
  <div class="sh-num">{num}</div>
</header>

<style>
  .sh {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: end;
    gap: 24px;
    padding: 20px 0 12px;
    border-bottom: 1px dashed var(--line);
    margin-bottom: 4px;
  }
  .sh-kicker {
    font-family: var(--mono-ui);
    font-size: 10px;
    letter-spacing: .2em;
    text-transform: uppercase;
    color: var(--ink-muted);
    margin-bottom: 8px;
  }
  .sh-title {
    margin: 0;
    font-family: var(--mono-display);
    font-size: 22px;
    color: var(--ink);
    letter-spacing: .02em;
    line-height: 1.1;
  }
  .sh-sub {
    margin-top: 4px;
    font-family: var(--mono-ui);
    font-size: 12px;
    color: var(--ink-dim);
  }
  .sh-num {
    font-family: var(--mono-display);
    font-size: 48px;
    color: var(--ink-muted);
    opacity: .5;
    line-height: 1;
  }
</style>
