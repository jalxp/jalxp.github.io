---
interface Props {
  title: string;
  hasMenu?: boolean;
  hasFooter?: boolean;
}
const { title, hasMenu = false, hasFooter = false } = Astro.props;
---
<div class="win">
  <div class="win-head">
    <div class="win-dots"><i class="r"/><i class="y"/><i class="g"/></div>
    <div class="win-title">{title}</div>
    <div class="win-spacer" />
  </div>
  {hasMenu && (
    <div class="win-menu"><slot name="menu" /></div>
  )}
  <div class="win-body"><slot /></div>
  {hasFooter && (
    <div class="win-footer"><slot name="footer" /></div>
  )}
</div>

<style>
  .win {
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    background: var(--panel);
    overflow: hidden;
  }
  .win-head {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 10px;
    padding: 8px 12px;
    border-bottom: 1px solid var(--line);
    background: var(--panel-2);
  }
  .win-dots { display: flex; gap: 6px; }
  .win-dots i {
    width: 10px; height: 10px; border-radius: 50%;
    display: inline-block;
  }
  .win-dots .r { background: #ff5f57; }
  .win-dots .y { background: #febc2e; }
  .win-dots .g { background: #28c840; }
  .win-title {
    text-align: center;
    font-family: var(--mono-ui);
    font-size: 11px;
    color: var(--ink-muted);
    letter-spacing: .04em;
  }
  .win-spacer { width: 54px; }
  .win-menu {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 6px 12px;
    border-bottom: 1px dashed var(--line-soft);
    background: var(--panel-2);
    font-family: var(--mono-ui);
    font-size: 11px;
    color: var(--ink-dim);
  }
  .win-body { padding: 18px 22px; }
  .win-footer {
    display: flex;
    justify-content: space-between;
    gap: 10px;
    padding: 8px 12px;
    border-top: 1px dashed var(--line-soft);
    background: var(--panel-2);
    font-family: var(--mono-ui);
    font-size: 10px;
    color: var(--ink-muted);
    letter-spacing: .1em;
    text-transform: uppercase;
  }
</style>
