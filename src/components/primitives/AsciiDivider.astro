---
interface Props {
  label: string;
}
const { label } = Astro.props;
---
<div class="ascii-div">
  <span class="line" />
  <span class="label">— {label} —</span>
  <span class="line" />
</div>

<style>
  .ascii-div {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 14px;
    align-items: center;
    padding: 8px 0;
  }
  .line {
    height: 0;
    border-top: 1px dashed var(--line);
  }
  .label {
    font-family: var(--mono-ui);
    font-size: 10px;
    letter-spacing: .2em;
    text-transform: uppercase;
    color: var(--ink-muted);
  }
</style>
