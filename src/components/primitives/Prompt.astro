---
interface Props {
  cmd: string;
}
const { cmd } = Astro.props;
---
<div class="prompt">
  <span class="ps1">$</span>
  <span class="cmd">{cmd}</span>
  <span class="caret" />
</div>

<style>
  .prompt {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--mono-body);
    font-size: 13px;
    color: var(--ink);
  }
  .ps1 { color: var(--accent); }
  .cmd { color: var(--ink-dim); }
  .caret {
    display: inline-block;
    width: 1ch;
    height: 1.1em;
    background: var(--accent);
    animation: blink 1s steps(2) infinite;
  }
  @keyframes blink {
    50% { opacity: 0; }
  }
</style>
